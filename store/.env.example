# Canonical production origin — success_url and OAuth redirects are built from
# this, NEVER from the incoming request host.
PUBLIC_SITE_URL=https://kezmodifications.com

# Discord OAuth application (required)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Fallbacks only — the settings table (editable in /admin) takes precedence.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Comma-separated Discord user ids that are always admins (bootstrap).
ADMIN_DISCORD_IDS=

# Where the SQLite db + uploaded files live. Defaults to ./data
DATA_DIR=./data
