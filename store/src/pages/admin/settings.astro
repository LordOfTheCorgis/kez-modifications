---
import AdminLayout from "../../layouts/AdminLayout.astro";

if (!Astro.locals.user) return Astro.redirect("/api/auth/login?next=/admin/settings");
if (!Astro.locals.user.isAdmin) return Astro.redirect("/");

const fields: { key: string; label: string; secret?: boolean; hint?: string }[] = [
  { key: "discord_bot_token", label: "Discord bot token", secret: true },
  { key: "discord_guild_id", label: "Discord guild (server) id" },
  { key: "stripe_test_secret_key", label: "Stripe TEST secret key", secret: true },
  { key: "stripe_test_webhook_secret", label: "Stripe TEST webhook secret", secret: true },
  { key: "stripe_live_secret_key", label: "Stripe LIVE secret key", secret: true },
  { key: "stripe_live_webhook_secret", label: "Stripe LIVE webhook secret", secret: true },
  { key: "webhook_sales", label: "Sales feed webhook URL", hint: "Discord webhook for sale notifications" },
  { key: "webhook_log", label: "Log feed webhook URL" },
  { key: "webhook_discounts", label: "Discounts feed webhook URL" },
  { key: "role_id_gold", label: "Gold tier role id", hint: "Discord role granted to gold subscribers" },
  { key: "stripe_price_gold", label: "Gold tier Stripe price id", hint: "price_… id of the recurring price" },
  { key: "role_id_platinum", label: "Platinum tier role id" },
  { key: "stripe_price_platinum", label: "Platinum tier Stripe price id" },
];
---

<AdminLayout section="settings" title="Settings">
  <div class="admin-section-header"><h1>Settings</h1></div>

  <div class="admin-card">
    <form class="admin-form" id="s-form">
      <div class="form-row">
        <label for="stripe_mode">Stripe mode</label>
        <select class="form-input" id="stripe_mode" data-key="stripe_mode">
          <option value="test">Test</option>
          <option value="live">Live</option>
        </select>
        <small class="label-hint">Test and live keys are stored separately — switching modes never mixes them.</small>
      </div>
      <div class="admin-form-2col">
        {
          fields.map((f) => (
            <div class="form-row">
              <label for={f.key}>{f.label}</label>
              <input
                class="form-input"
                id={f.key}
                data-key={f.key}
                type={f.secret ? "password" : "text"}
                placeholder={f.secret ? "leave blank to keep current" : ""}
                autocomplete="off"
              />
              {f.hint && <small class="label-hint">{f.hint}</small>}
            </div>
          ))
        }
      </div>
      <div class="error-note" id="s-error"></div>
      <div class="admin-form-actions">
        <button class="btn btn-primary" type="submit">Save settings</button>
        <span id="s-saved" style="color:#4ade80;font-size:0.8rem;align-self:center;"></span>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const err = (m: string) => (document.getElementById("s-error")!.textContent = m);

  async function load() {
    const res = await fetch("/api/admin/settings");
    const data = await res.json();
    if (!res.ok) {
      err(data.error ?? "Failed to load");
      return;
    }
    for (const el of document.querySelectorAll<HTMLInputElement>("[data-key]")) {
      const value = data.settings[el.dataset.key!] ?? "";
      // Secrets come back masked; keep the field empty so blank = unchanged.
      if (el.type === "password") {
        el.placeholder = value ? "***** set — enter to replace" : "not set";
      } else {
        el.value = value;
      }
    }
  }

  document.getElementById("s-form")!.addEventListener("submit", async (e) => {
    e.preventDefault();
    err("");
    const body: Record<string, string> = {};
    for (const el of document.querySelectorAll<HTMLInputElement>("[data-key]")) {
      if (el.value !== "") body[el.dataset.key!] = el.value;
      else if (el.type !== "password") body[el.dataset.key!] = "";
    }
    const res = await fetch("/api/admin/settings", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    if (!res.ok) {
      err("Save failed");
      return;
    }
    document.getElementById("s-saved")!.textContent = "Saved ✓";
    setTimeout(() => (document.getElementById("s-saved")!.textContent = ""), 2500);
    for (const el of document.querySelectorAll<HTMLInputElement>("[data-key]")) {
      if (el.type === "password") el.value = "";
    }
    load();
  });

  load();
</script>
